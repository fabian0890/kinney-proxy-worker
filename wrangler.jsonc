/**
 * Wrangler config with environments: staging(dev), beta, production
 */
 {
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "kinney-proxy-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-24",
	"observability": {
	  "enabled": true
	},
	"compatibility_flags": ["nodejs_compat"],
  
	/**
	 * Vars base
	 */
	"vars": {
		"KPH_BASE_URL": "https://stage.kinneydrugs.com",
	  	"SYNERIO_BASE_URL": "https://engage-api-ctest.synerio.com",
	  	"HEROKU_BASE_URL": "https://kinney-drugs-mobile-app-e34533420f49.herokuapp.com",
	  	"SFMC_BASE_URL": "https://cloud.communications.kinneydrugs.com",
	  	"SALESFORCE_BASE_URL": "https://kinneydrugs.my.salesforce.com",
	  	"ALLOWED_ORIGINS": "http://localhost:8100,https://client.hivegroup.nyc"
	},
  
	/**
	 * Environments
	 */
	"env": {
	  "staging": {
		"vars": {
			"KPH_BASE_URL": "https://stage.kinneydrugs.com",
			"SYNERIO_BASE_URL": "https://engage-api-ctest.synerio.com",
			"HEROKU_BASE_URL": "https://kinney-drugs-mobile-app-e34533420f49.herokuapp.com",
			"SFMC_BASE_URL": "https://cloud.communications.kinneydrugs.com",
			"SALESFORCE_BASE_URL": "https://kinneydrugs.my.salesforce.com",
			"ALLOWED_ORIGINS": "http://localhost:8100,https://client.hivegroup.nyc"
		}
	  },
  
	  "beta": {
		"vars": {
			"KPH_BASE_URL": "https://pilot.kinneydrugs.com",
			"SYNERIO_BASE_URL": "https://engage-api-ctest.synerio.com",
			"HEROKU_BASE_URL": "https://kinney-drugs-mobile-app-e34533420f49.herokuapp.com",
			"SFMC_BASE_URL": "https://cloud.communications.kinneydrugs.com",
			"SALESFORCE_BASE_URL": "https://kinneydrugs.my.salesforce.com",
			"ALLOWED_ORIGINS": "http://localhost:8100,https://client.hivegroup.nyc"
		}
	  },
  
	  "production": {
		"vars": {
			"KPH_BASE_URL": "https://kinneydrugs.com",
			"SYNERIO_BASE_URL": "https://engage-api-ctest.synerio.com",
			"HEROKU_BASE_URL": "https://kinney-drugs-mobile-app-e34533420f49.herokuapp.com",
			"SFMC_BASE_URL": "https://cloud.communications.kinneydrugs.com",
			"SALESFORCE_BASE_URL": "https://kinneydrugs.my.salesforce.com",
			"ALLOWED_ORIGINS": "http://localhost:8100,https://client.hivegroup.nyc"
		}
	  }
	}
  }